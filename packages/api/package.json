{
  "name": "@time/api",
  "version": "0.1.0",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/api",
    "db:ensure": "bun run src/db/ensure.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:init": "bun run db:ensure && bun run db:push && bun run db:seed"
  },
  "dependencies": {
    "@time/shared": "workspace:*",
    "hono": "^4.12.14",
    "drizzle-orm": "^0.45.2",
    "@hono/zod-validator": "^0.7.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.9"
  }
}
