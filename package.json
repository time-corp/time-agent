{
  "name": "time-agent",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev:api": "pnpm --filter @time/api dev",
    "dev:web": "pnpm --filter @time/web dev",
    "dev": "pnpm -r --parallel --filter @time/api --filter @time/web dev",
    "build": "pnpm --filter @time/web build && pnpm --filter @time/api build",
    "test": "pnpm -r --if-present test"
  },
  "workspaces": [
    "packages/*"
  ]
}
